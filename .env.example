# LinkedIn credentials — required
LINKEDIN_EMAIL=your.email@example.com
LINKEDIN_PASSWORD=your-password-here

# AI provider — pick one. The factory uses LLM_PROVIDER to choose.
LLM_PROVIDER=anthropic              # anthropic | openai
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Run knobs
HEADLESS=false                      # set true once login state is persisted
TOP_N_POSTS=10                      # how many feed posts to collect
TOP_K_FOR_COMMENTS=3                # how many to draft comments for (Level 2/3)
LIKE_POSTS=true                     # actually click the like button on top N
RUN_LEVEL=3                         # 1 | 2 | 3

# Warmup for brand-new accounts: how many recommended people to follow
# before collecting the feed. Set to 0 to disable. The bot only clicks
# "Follow", never "Connect" (the latter requires acceptance).
WARMUP_FOLLOWS=0

# If the home feed is still empty after warmup, fall back to this
# hashtag feed (e.g. "startups", "engineering"). Empty string disables.
FALLBACK_HASHTAG=startups
